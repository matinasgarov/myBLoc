# Required — Groq LLM
GROQ_API_KEY=your_groq_api_key_here

# HMAC secret for signing /api/places response → verified in /api/analyze.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In production this MUST be set, or /api/analyze rejects every request (fail-closed).
PLACES_SIGNING_SECRET=

# Feedback email (Resend)
RESEND_API_KEY=your_resend_api_key_here
FEEDBACK_EMAIL=destination@example.com
# Optional — sender address. Must be a verified domain in Resend for reliable delivery.
# Defaults to Resend's shared sandbox (flaky deliverability).
RESEND_FROM=myblocate Feedback <feedback@yourdomain.com>

# Rate-limit store (Upstash Redis). If unset, an in-memory fallback is used (single-instance only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — Cloudflare Turnstile (CAPTCHA) for /api/feedback.
# If TURNSTILE_SECRET is unset, verification is skipped. When set, the client must
# send the token as `turnstileToken` in the feedback POST body.
TURNSTILE_SECRET=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional
NEXT_PUBLIC_SITE_URL=https://myblocate.com
OVERPASS_CONTACT=myblocate/1.0 (+https://myblocate.com)
OVERPASS_DEBUG=0
